---
import DemoVideo from "../components/DemoVideo.astro";
import ExtLink from "../components/ExtLink.astro";
import MatrixTable from "../components/MatrixTable.astro";
import PipelineDiagram from "../components/PipelineDiagram.astro";
import {
  certifications,
  education,
  email,
  experience,
  extracurriculars,
  github,
  hero,
  linkedin,
  projects,
  skills,
} from "../data/resume";
import Base from "../layouts/Base.astro";
---

<Base>
  <section class="hero" aria-label="Introduction">
    <div class="container">
      <p class="kicker">{hero.kicker}</p>
      <h1>Ilyes Jamoussi</h1>
      <p class="lede">{hero.lede}</p>
      <ul class="now-list">
        {hero.now.map((item) => <li>{item}</li>)}
      </ul>
      <div class="hero-links">
        <ExtLink href={github}>GitHub</ExtLink>
        <ExtLink href={linkedin}>LinkedIn</ExtLink>
        <a href={`mailto:${email}`}>Email</a>
      </div>
    </div>
  </section>

  <section id="projects" class="section" aria-labelledby="projects-title">
    <div class="container container--wide">
      <h2 class="section-title" id="projects-title">Selected projects</h2>
      <ol class="projects">
        {
          projects.map((project) => (
            <li class="project">
              <div class="project-body">
                <div class="project-head">
                  <h3 class="project-name">{project.name}</h3>
                  <div class="project-links">
                    <ExtLink href={project.repo}>code</ExtLink>
                    {project.demo && (
                      <ExtLink href={project.demo}>live demo</ExtLink>
                    )}
                  </div>
                </div>
                <p class="project-tagline">{project.tagline}</p>
                <ul class="project-bullets">
                  {project.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
                {project.sample && (
                  <figure class="sample">
                    <blockquote class="sample-text">
                      “{project.sample.text}”
                    </blockquote>
                    <figcaption class="sample-caption">
                      prompt “{project.sample.prompt}” ·{" "}
                      {project.sample.settings}
                    </figcaption>
                  </figure>
                )}
                <p class="project-meta">
                  {project.metrics.length > 0 && (
                    <span class="project-metrics">
                      {project.metrics.join(" · ")}
                    </span>
                  )}
                  <span class="project-stack">{project.stack.join(" · ")}</span>
                </p>
              </div>
              {(project.video ??
                project.diagram ??
                project.confusionMatrix) && (
                <div class="project-media">
                  {project.video && <DemoVideo video={project.video} />}
                  {project.diagram === "minigpt-pipeline" && (
                    <PipelineDiagram />
                  )}
                  {project.confusionMatrix && (
                    <MatrixTable matrix={project.confusionMatrix} />
                  )}
                </div>
              )}
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section id="work" class="section" aria-labelledby="work-title">
    <div class="container">
      <h2 class="section-title" id="work-title">Experience</h2>
      <div class="entries">
        {
          experience.map((entry) => (
            <article class="entry">
              <p class="entry-period">{entry.period}</p>
              <div>
                <h3 class="entry-org">{entry.org}</h3>
                <p class="entry-role">{entry.role}</p>
                <ul class="entry-bullets">
                  {entry.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="education" class="section" aria-labelledby="education-title">
    <div class="container">
      <h2 class="section-title" id="education-title">
        Education & certifications
      </h2>
      <div class="entries">
        {
          education.map((entry) => (
            <article class="entry">
              <p class="entry-period">{entry.period}</p>
              <div>
                <h3 class="entry-org">{entry.school}</h3>
                <p class="entry-role">{entry.degree}</p>
              </div>
            </article>
          ))
        }
      </div>
      <ul class="cert-list">
        {
          certifications.map((cert) => (
            <li>
              <span class="cert-name">{cert.name}</span>
              <span class="cert-date">{cert.date}</span>
              <ExtLink class="cert-verify" href={cert.verifyUrl}>
                verify
              </ExtLink>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section
    id="extracurriculars"
    class="section"
    aria-labelledby="extracurriculars-title"
  >
    <div class="container">
      <h2 class="section-title" id="extracurriculars-title">
        Extracurriculars
      </h2>
      <div class="entries">
        {
          extracurriculars.map((entry) => (
            <article class="entry">
              <p class="entry-period">{entry.period}</p>
              <div>
                <h3 class="entry-org">{entry.org}</h3>
                <p class="entry-role">{entry.role}</p>
                <ul class="entry-bullets">
                  {entry.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="skills" class="section" aria-labelledby="skills-title">
    <div class="container">
      <h2 class="section-title" id="skills-title">Skills</h2>
      <dl class="skills-list">
        {
          skills.map((group) => (
            <div>
              <dt>{group.label}</dt>
              <dd>{group.items.join(" · ")}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <section id="contact" class="section" aria-labelledby="contact-title">
    <div class="container">
      <h2 class="section-title" id="contact-title">Contact</h2>
      <p class="contact-lede">
        I’m looking for software engineering and machine learning internships.
        The fastest way to reach me is email.
      </p>
      <ul class="contact-links">
        <li><a href={`mailto:${email}`}>{email}</a></li>
        <li><ExtLink href={github}>github.com/Ilyes-Jamoussi</ExtLink></li>
        <li>
          <ExtLink href={linkedin}>
            linkedin.com/in/ilyes-jamoussi-b4aa94251
          </ExtLink>
        </li>
      </ul>
    </div>
  </section>
</Base>
