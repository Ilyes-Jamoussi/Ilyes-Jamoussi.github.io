{
  "name": "ilyes-jamoussi.github.io",
  "version": "2.0.0",
  "description": "Personal site of Ilyes Jamoussi — statically generated with Astro, deployed on GitHub Pages",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.3.0"
  },
  "scripts": {
    "dev": "npm run generate:assets && astro dev",
    "build": "npm run generate:assets && astro build",
    "preview": "astro preview",
    "generate:assets": "tsx scripts/generate-assets.ts",
    "typecheck": "astro check",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "astro": "^5.18.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.2.17",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "satori": "^0.26.0",
    "tsx": "^4.22.5",
    "typescript-eslint": "^8.62.1"
  }
}
